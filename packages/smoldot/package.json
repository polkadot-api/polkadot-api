{
  "name": "@polkadot-api/smoldot",
  "version": "0.3.16",
  "author": "Josep M Sobrepere (https://github.com/josepot)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polkadot-api/polkadot-api.git"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "module": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./from-node-worker": {
      "types": "./dist/from-node-worker/from-node-worker.d.ts",
      "module": "./dist/from-node-worker/from-node-worker.mjs",
      "import": "./dist/from-node-worker/from-node-worker.mjs",
      "default": "./dist/from-node-worker/from-node-worker.mjs"
    },
    "./from-worker": {
      "types": "./dist/from-worker/from-worker.d.ts",
      "module": "./dist/from-worker/from-worker.mjs",
      "import": "./dist/from-worker/from-worker.mjs",
      "default": "./dist/from-worker/from-worker.mjs"
    },
    "./node-worker": {
      "types": "./dist/node-worker/node-worker.d.ts",
      "module": "./dist/node-worker/node-worker.mjs",
      "import": "./dist/node-worker/node-worker.mjs",
      "default": "./dist/node-worker/node-worker.mjs"
    },
    "./worker": {
      "types": "./dist/worker/worker.d.ts",
      "module": "./dist/worker/worker.mjs",
      "import": "./dist/worker/worker.mjs",
      "default": "./dist/worker/worker.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "browser": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "from-worker",
    "worker"
  ],
  "scripts": {
    "build-core": "tsc --noEmit && rollup -c",
    "build": "pnpm build-core",
    "test": "echo 'no tests'",
    "lint": "prettier --check README.md \"src/**/*.{js,jsx,ts,tsx,json,md}\"",
    "format": "prettier --write README.md \"src/**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "dependencies": {
    "@polkadot-api/smoldot-patch": "102.0.0",
    "@types/node": "^25.5.0",
    "smoldot": "2.0.40"
  }
}
